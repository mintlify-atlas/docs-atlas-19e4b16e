  "keyFeatures": [
    "Dashboard with real-time KPI stats (revenue, new users, churn rate)",
    "Project management with create, edit, filter, and paginate operations",
    "User directory with detailed profile inspection and audit trail",
    "Integrated API engineering panel with error simulation (401, 404, 500)",
    "Layered architecture with custom hooks separating business logic from UI",
    "Centralized HTTP client with Bearer token authentication",
    "Mock server intercepting fetch for local development and demo",
    "Collapsible sidebar layout with role-based user display"
  ],
  "publicApiSurface": [
    "apiGetDashboard({ token })",
    "apiCreateProject({ token, payload })",
    "apiToggleProjectStatus({ token, id })",
    "apiUpdateProject({ token, id, payload })",
    "apiClient.getUsers()",
    "apiClient.getUserPosts(userId)",
    "apiClient.getPostComments(postId)",
    "useFetch(fetchFn, autoExecute, deps)",
    "useForm(initialValues, validate)",
    "useDashboard()",
    "useProjectForm(token, onSuccess, setSelectedId)",
    "useUsers()",
    "useToggle(initial)",
    "window.setSimulatedError(code)",
    "window.SIMULATE_ERROR",
    "httpClient.get(endpoint, options)",
    "httpClient.post(endpoint, data, options)",
    "httpClient.put(endpoint, data, options)",
    "httpClient.patch(endpoint, data, options)",
    "httpClient.delete(endpoint, options)"
  ]
}
